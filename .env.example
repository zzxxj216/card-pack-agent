# ==========================================
# card-pack-agent — env template
# Copy to .env and fill in. Never commit .env.
# ==========================================

# --- Runtime mode ---
# "mock" = no external API calls, all LLM/image/vector ops return canned data (for local smoke tests)
# "dev"  = real APIs, local Postgres + Qdrant
# "prod" = real APIs, managed Postgres + Qdrant
APP_MODE=mock

# --- Anthropic ---
ANTHROPIC_API_KEY=
# Models — pinned per tier (see config.py for routing)
ANTHROPIC_MODEL_PLANNER=claude-opus-4-7
ANTHROPIC_MODEL_GENERATOR=claude-sonnet-4-6
ANTHROPIC_MODEL_REVIEWER=claude-opus-4-7
ANTHROPIC_MODEL_JUDGE=claude-opus-4-7

# --- Image generation ---
# Default provider for orchestrator (when not explicitly overridden in code).
# Values:
#   mock | flux_pro | flux_schnell | openai_image | replicate
#   seedream_v45 | flux_kontext_max | midjourney_txt2img | jiekou_openai
#   gemini_flash_image_edit
IMAGE_PROVIDER=mock
# API key usage depends on provider:
#   flux_pro / flux_schnell / replicate → Replicate token
#   openai_image                         → OpenAI API key
IMAGE_API_KEY=
# For ReplicateProvider: model slug, e.g. stability-ai/sdxl or owner/model:version
IMAGE_MODEL=
IMAGE_CONCURRENCY=10

# jiekou.ai proxy key (shared by seedream / flux-kontext / midjourney / jiekou-openai)
JIEKOU_API_KEY=
JIEKOU_BASE_URL=https://api.jiekou.ai

# Gemini image endpoint key (preferred for gemini_flash_image_edit; falls back to JIEKOU_API_KEY)
GEMINI_API_KEY=

# Async provider polling budget (flux-kontext / midjourney)
ASYNC_POLL_INTERVAL_S=2.0
ASYNC_POLL_MAX_ATTEMPTS=60

# --- Postgres ---
POSTGRES_DSN=postgresql://cardpack:cardpack@localhost:5432/cardpack

# --- Qdrant ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# --- Object storage (R2 / S3) ---
STORAGE_PROVIDER=local
STORAGE_BUCKET=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_ENDPOINT=
STORAGE_LOCAL_PATH=./generated

# --- Knowledge base ---
KNOWLEDGE_PATH=./knowledge

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json
